    "document_number": { "description": "Generic alphanumeric ID — PAN, Aadhaar, Voter ID, DL, etc." },
    "passport_number": { "description": "Passport book number — 1-2 letters + 7-8 digits, or 9-char ICAO alphanumeric" },
    "visa_number":     { "description": "Visa sticker number (2-3L+7D) or e-Visa numeric string (12-13 digits)" },
    "text":            { "description": "Free-form short text value" },
    "address":         { "description": "Multi-part address string" },
    "gender":          { "description": "M / F / Male / Female / Other / X" },
    "number":          { "description": "Pure numeric value (e.g. pincode)" },
    "mrz":             { "description": "ICAO Machine Readable Zone line" },
    "blood_group":     { "description": "ABO+Rh type: A+, AB-, O POS, B NEGATIVE, etc." },
    "dna_marker":      { "description": "STR allele pairs (D3S1358:15,16) or numeric haplotype string" },
    "state_code":      { "description": "Indian state/UT 2-letter ISO code — AP, MH, DL, KA, TN, etc." },
    "vid_number":      { "description": "Aadhaar Virtual ID — 16 digits, optionally grouped 4-4-4-4" }
  }
